<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E5E5E5"
    android:orientation="vertical">

    <!-- Modern Header with Shopper Info -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_back"
                app:tint="#212121"/>

            <!-- Shopper Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivShopperAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImageView"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvShopperNameTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nguyễn Minh"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_online_indicator"/>

                    <TextView
                        android:id="@+id/tvShopperStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Đang mua hàng tại chợ..."
                        android:textColor="#4CAF50"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Đơn hàng của bạn -->
    <LinearLayout
        android:id="@+id/orderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_food"
                app:tint="#00B14F"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Đơn hàng của bạn"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:id="@+id/containerOrderChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/orderChip1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_ingredient"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    tools:text="Thịt bò nạm 1kg"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/orderChip2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_ingredient"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    tools:text="Rau thơm 1 bó"
                    tools:visibility="visible"/>

                <TextView
                    android:id="@+id/orderChipMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_ingredient"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="#5E5E5E"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="+2 món khác"
                    tools:visibility="visible"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Quick Replies Section -->
    <LinearLayout
        android:id="@+id/quickRepliesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gợi ý nhanh"
            android:textSize="12sp"
            android:textColor="#5E5E5E"
            android:layout_marginBottom="6dp"
            android:layout_marginStart="4dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/quickReply1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Được, lấy đi chị"
                    android:background="@drawable/bg_quick_reply"
                    android:textColor="#008F4C"
                    android:textSize="13sp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/quickReply2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không cần món đó"
                    android:background="@drawable/bg_quick_reply"
                    android:textColor="#008F4C"
                    android:textSize="13sp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/quickReply3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thay thế"
                    android:background="@drawable/bg_quick_reply"
                    android:textColor="#008F4C"
                    android:textSize="13sp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/quickReply4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cảm ơn bạn"
                    android:background="@drawable/bg_quick_reply"
                    android:textColor="#008F4C"
                    android:textSize="13sp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <!-- Image Picker Button -->
        <ImageView
            android:id="@+id/btnImagePicker"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_image"
            app:tint="#5E5E5E"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Message Input -->
        <EditText
            android:id="@+id/edtMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_field"
            android:hint="Nhắn tin cho shopper..."
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:paddingHorizontal="16dp"
            android:textColor="#212121"
            android:textColorHint="#BDBDBD"
            android:textSize="15sp"/>

        <!-- Send Button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_send"
            app:backgroundTint="#00B14F"
            app:tint="#FFFFFF"
            app:fabSize="mini"
            app:elevation="0dp"/>

    </LinearLayout>

</LinearLayout>