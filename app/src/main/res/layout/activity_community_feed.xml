<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Chợ Đồng Hương"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#80FFFFFF"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🔍"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Search bar (hidden by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchBarContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/toolbar"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Tìm kiếm bài đăng..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textSize="14sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Category filter chips -->
    <HorizontalScrollView
        android:id="@+id/chipScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbar"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/chipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_filter_active"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Tất cả"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipNongSan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="🌾 Nông sản"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipDacSan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="🍜 Đặc sản"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipRaoVat"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="📢 Rao vặt"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipGomChung"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="👥 Gom chung"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Label Vùng miền -->
    <TextView
        android:id="@+id/tvRegionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/chipScroll"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:text="🗺️ Vùng miền"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Region filter chips -->
    <HorizontalScrollView
        android:id="@+id/regionChipScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvRegionLabel"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/regionChipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/chipMienBac"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="🏔️ Miền Bắc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipMienTrung"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="⛰️ Miền Trung"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipMienNam"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_filter_inactive"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="🌴 Miền Nam"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Feed list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/regionChipScroll"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

    <!-- FAB: Create Post -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreatePost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="Đăng bài"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary"
        app:tint="@color/white" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/chipScroll"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏘️"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Chưa có bài đăng nào"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />
    </LinearLayout>
</RelativeLayout>
